<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.headlessflower.Promptr</id>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <name>Promptr</name>
  <summary>GNOME teleprompter for smooth script reading</summary>

  <description>
    <p>
      Promptr is a GTK4 and libadwaita teleprompter for Linux. It supports adjustable
      scroll speed and text size, fullscreen mode, mirror mode, and a clean reading
      interface for creators, presenters, and streamers.
    </p>
    <p>
      Promptr can load plain text, Markdown, DOCX, ODT, RTF, and PDF files, making it
      easy to read scripts in a distraction-free desktop app.
    </p>
  </description>

  <launchable type="desktop-id">com.headlessflower.Promptr.desktop</launchable>

  <categories>
    <category>Office</category>
  </categories>

  <keywords>
    <keyword>teleprompter</keyword>
    <keyword>script</keyword>
    <keyword>prompt</keyword>
    <keyword>presentation</keyword>
    <keyword>reading</keyword>
  </keywords>

  <content_rating type="oars-1.1"/>

  <releases>
    <release version="0.1.0" date="2026-04-07">
      <description>
        <p>Initial public release of Promptr.</p>
      </description>
    </release>
  </releases>

